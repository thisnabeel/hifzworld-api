<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= content_for?(:title) ? yield(:title) : "Hifz.World" %></title>
  <style>
    :root {
      --bg: #0f1214;
      --card: #1a1e22;
      --text: #f2f4f5;
      --muted: #9aa3a8;
      --accent: #00d4ff;
      --line: #2a3136;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      background: radial-gradient(1200px 600px at 10% -10%, #16303a 0%, var(--bg) 55%);
      color: var(--text);
      line-height: 1.6;
      min-height: 100vh;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    header {
      max-width: 720px;
      margin: 0 auto;
      padding: 28px 20px 0;
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      align-items: baseline;
      justify-content: space-between;
    }
    .brand { font-weight: 700; font-size: 1.15rem; color: var(--text); }
    nav { display: flex; gap: 14px; flex-wrap: wrap; font-size: 0.95rem; }
    main {
      max-width: 720px;
      margin: 0 auto;
      padding: 28px 20px 64px;
    }
    .card {
      background: color-mix(in srgb, var(--card) 92%, transparent);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 28px 24px;
    }
    h1 { margin: 0 0 12px; font-size: 1.75rem; line-height: 1.25; }
    h2 { margin: 28px 0 8px; font-size: 1.15rem; }
    p, li { color: var(--muted); }
    ul { padding-left: 1.2rem; }
    .meta { font-size: 0.9rem; color: var(--muted); margin-bottom: 20px; }
    footer {
      max-width: 720px;
      margin: 0 auto;
      padding: 0 20px 40px;
      color: var(--muted);
      font-size: 0.85rem;
    }
  </style>
</head>
<body>
  <header>
    <a class="brand" href="/">Hifz.World</a>
    <nav>
      <a href="/support">Support</a>
      <a href="/privacy">Privacy</a>
      <a href="/contact">Contact</a>
    </nav>
  </header>
  <main>
    <div class="card">
      <%= yield %>
    </div>
  </main>
  <footer>
    © <%= Time.current.year %> Hifz.World · Contact <a href="mailto:nabeel@iqra.life">nabeel@iqra.life</a>
  </footer>
</body>
</html>
